#!/bin/bash

{{ if .isLinux }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"

if [ ! -d "${HOME}/.oh-my-zsh" ]; then
  info "Installing Oh My Zsh..."
  run <<EOF
wget https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh &>/dev/null \
  && sh install.sh --keep-zshrc --unattended &>/dev/null \
  && rm install.sh
EOF

  info "Setting up temporary minimalist .zshrc..."
  cat <<'EOF' > "${HOME}/.zshrc"
export ZSH="${HOME}/.oh-my-zsh"
ZSH_THEME="agnoster"
plugins=(git nvm)
source $ZSH/oh-my-zsh.sh
EOF

else
  info "Oh My Zsh is already installed. Updating..."
  run <<EOF
git -C ${HOME}/.oh-my-zsh pull
EOF
fi

if [ -f "${HOME}/.zshrc" ]; then
  info "Reloading .zshrc..."
  zsh -c "source ${HOME}/.zshrc"
fi

{{ end }}
