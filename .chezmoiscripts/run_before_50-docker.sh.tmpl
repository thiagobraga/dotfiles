#!/bin/bash

{{ if .isLinux }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"

{{ if .isWsl -}}
if ! command -v docker &>/dev/null; then
  warning "Docker not found in WSL. Ensure Docker Desktop WSL Integration is enabled."
else
  info "Docker found via WSL Integration. Skipping native installation."
fi
{{ else -}}
if ! command -v docker &>/dev/null; then
  info "Installing Docker via official convenience script..."
  run <<EOF
curl -fsSL https://get.docker.com -o get-docker.sh \
  && sudo sh get-docker.sh \
  && rm get-docker.sh
EOF
else
  info "Docker is already installed. Skipping get.docker.com script to avoid warnings."
fi

if ! groups $USER | grep -q "docker"; then
  info "Adding user $USER to the docker group..."
  run <<EOF
sudo usermod -aG docker $USER
EOF
fi

! docker compose version &>/dev/null \
  && info "Installing Docker Compose plugin..." \
  || info "Updating Docker Compose plugin..."
run <<EOF
sudo apt-get install -y docker-compose-plugin &>/dev/null
EOF
{{ end -}}

{{ end }}
