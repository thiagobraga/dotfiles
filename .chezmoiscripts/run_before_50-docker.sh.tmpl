#!/bin/bash
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"

info "$(printf "${ORANGE}[Docker]${NC}") Installing/Checking Docker and user group membership..."

if ! command -v docker &> /dev/null; then
  info "Installing Docker via official convenience script..."
  run <<EOF
curl -fsSL https://get.docker.com -o get-docker.sh && sudo sh get-docker.sh && rm get-docker.sh
EOF
else
  info "Docker is already installed."
fi

if ! groups $USER | grep -q "\bdocker\b"; then
  info "Adding user $USER to the docker group..."
  run <<EOF
sudo usermod -aG docker $USER
newgrp docker
EOF
else
  info "User is already in the docker group."
fi

info "$(printf "${ORANGE}[Docker]${NC}") Enforcing Docker Compose installation..."
run <<EOF
sudo apt-get install -y docker-compose-plugin &>/dev/null
EOF
