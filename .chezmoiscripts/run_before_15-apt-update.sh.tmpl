#!/bin/bash

{{ if .isLinux }}

source '{{ .chezmoi.sourceDir }}/.helpers/utils.sh'

info "Updating apt repositories..."
sudo apt-get update &>/dev/null
success

info "Reconfiguring dpkg..."
sudo dpkg --configure -a &>/dev/null
success

upgrade_size=$(sudo apt-get upgrade --assume-no 2>/dev/null | awk '/^Need to get/ {print $4, $5}')
[ -n "$upgrade_size" ] \
  && info "Upgrading installed apt packages (${upgrade_size})..." \
  || info "Upgrading installed apt packages..."
sudo apt-get upgrade -y &>/dev/null
success

info "Autoremoving unused packages..."
sudo apt-get autoremove -y &>/dev/null
success

info "Cleaning apt cache..."
sudo apt-get clean &>/dev/null
success

{{ end }}
