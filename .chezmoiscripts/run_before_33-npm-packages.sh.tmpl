#!/bin/bash

{{ if and .isLinux (not .hasAVX) }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"
info "Installing npm global packages (fallback for non-AVX hardware)..."

# Ensure nvm-installed node/npm is in PATH
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"

run <<EOF
npm i -g \
  @anthropic-ai/claude-code \
  @kilocode/cli \
  browser-sync \
  n8n \
  openclaw \
  opencode-ai \
  vercel \
  yarn \
  &>/dev/null
EOF

info "Testing npm global packages..."
run -n1 <<EOF
claude -v
EOF

run -n1 <<EOF
browser-sync --version
EOF

run -n1 <<EOF
kilo --version
EOF

run -n1 <<EOF
n8n -v
EOF

run -n1 <<EOF
openclaw -v
EOF

run -n1 <<EOF
opencode -v
EOF

run -n1 <<EOF
vercel -v
EOF

run -n1 <<EOF
yarn -v
EOF

info "Installing Antigravity Awesome Skills..."
run <<EOF
npx antigravity-awesome-skills &>/dev/null
test -d ~/.gemini/antigravity/skills && echo "Skills installed"
EOF

success
{{ end }}
