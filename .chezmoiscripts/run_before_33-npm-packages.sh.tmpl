#!/bin/bash

{{- if and .isLinux .isFull }}

source '{{ .chezmoi.sourceDir }}/.helpers/utils.sh'

info "Installing npm global packages..."
export NVM_DIR="${HOME}/.nvm"
[ -s "${NVM_DIR}/nvm.sh" ] && \. "${NVM_DIR}/nvm.sh" &>/dev/null

for pkg in \
  @openai/codex \
  opencode-ai \
  yarn; do
  npm i -g "$pkg" &>/dev/null
done
success

{{- end }}
