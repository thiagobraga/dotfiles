#!/bin/bash

{{ if .isUbuntu }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"

info "Installing essential apt packages..."
run <<EOF
sudo apt-get install -y \\
  apt-transport-https \\
  bat \\
  build-essential \\
  ca-certificates \\
  curl \\
  dislocker \\
  eza \\
  fzf \\
  git \\
  gpg \\
  htop \\
  make \\
  neovim \\
  ntfs-3g \\
  numlockx \\
  samba \\
  unzip \\
  vim \\
  wget \\
  zsh \\
  zstd \\
  &>/dev/null
EOF

{{ end }}
