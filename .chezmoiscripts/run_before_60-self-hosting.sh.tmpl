#!/bin/bash

{{ if .isLinux }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"
info "Self-hosting services (llama.cpp, paperless-ngx, glance)..."

export SELF_HOSTED_DIR="${HOME}/projects/self-hosted"
mkdir -p "${SELF_HOSTED_DIR}/{llama.cpp,paperless-ngx,glance}"

if ! docker image inspect ghcr.io/ggml-org/llama.cpp:server &>/dev/null; then
  info "Pulling llama.cpp server Docker image..."
  run <<EOF
docker pull ghcr.io/ggml-org/llama.cpp:server
EOF
fi

if [ ! -f "${SELF_HOSTED_DIR}/paperless-ngx/docker-compose.yml" ]; then
  info "Fetching Paperless-ngx docker-compose example..."
  run <<EOF
wget -q "https://raw.githubusercontent.com/paperless-ngx/paperless-ngx/main/docker/compose/docker-compose.postgres.yml" -O "$SELF_HOSTED_DIR/paperless-ngx/docker-compose.yml"
wget -q "https://raw.githubusercontent.com/paperless-ngx/paperless-ngx/main/docker/compose/.env" -O "$SELF_HOSTED_DIR/paperless-ngx/.env"
EOF
  warning "Paperless-ngx is ready for configuration in ~/services/paperless-ngx/."
  warning "Manually run the official setup script if you prefer interactive configuration: bash -c \"\$(curl -L https://raw.githubusercontent.com/paperless-ngx/paperless-ngx/main/install-paperless-ngx.sh)\""
fi

if [ ! -f "${SELF_HOSTED_DIR}/glance/docker-compose.yml" ]; then
  info "Fetching Glance docker-compose template..."
  run <<EOF
cd "${SELF_HOSTED_DIR}/glance"
curl -sL https://github.com/glanceapp/docker-compose-template/archive/refs/heads/main.tar.gz | tar -xzf - --strip-components 2
EOF
fi

info "$(printf "${ORANGE}[Self-host]${NC}") Starting self-hosted services (only if docker-compose.yml exists)..."

for service in "glance" "llama.cpp" "paperless-ngx"; do
  if [ -f "${SELF_HOSTED_DIR}/${service}/docker-compose.yml" ]; then
    info "Starting ${service}..."
    run <<EOF
cd "${SELF_HOSTED_DIR}/${service}"
docker compose up -d
EOF
  fi
done

{{ end }}
