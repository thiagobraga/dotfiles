# -----------------------------------------------------------------------------
# Windows App Installation (Winget)
# -----------------------------------------------------------------------------
{{ if eq .chezmoi.os "windows" }}

$apps = @(
  "BurntSushi.ripgrep.MSVC",
  "Neovim.Neovim",
  "JanDeDobbeleer.OhMyPosh",
  "Microsoft.WindowsTerminal",
  "Microsoft.VisualStudioCode"
)

foreach ($appId in $apps) {
  $installed = winget list --id $appId --source winget 2>$null
  if ($null -eq $installed) {
    Write-Host "Installing $appId..." -ForegroundColor Cyan
    winget install --id $appId --silent --accept-package-agreements --accept-source-agreements
  } else {
    Write-Host "$appId is already installed. Skipping." -ForegroundColor Gray
  }
}

# -----------------------------------------------------------------------------
# Fira Code Nerd Font Installation
# -----------------------------------------------------------------------------
Write-Host "Installing Fira Code Nerd Font..." -ForegroundColor Cyan
$fontVersion = "3.2.1"
$fontUrl = "https://github.com/ryanoasis/nerd-fonts/releases/download/v$fontVersion/FiraCode.zip"
$tempPath = "$env:TEMP\FiraCode.zip"
$extractPath = "$env:TEMP\FiraCode"

# Download and extract
Invoke-WebRequest -Uri $fontUrl -OutFile $tempPath -UseBasicParsing
Expand-Archive -Path $tempPath -DestinationPath $extractPath -Force

# Install fonts
$shell = New-Object -ComObject Shell.Application
$fontsFolder = $shell.Namespace(0x14)  # 0x14 = Fonts folder
Get-ChildItem -Path $extractPath -Filter "*.ttf" | ForEach-Object {
  $fontsFolder.CopyHere($_.FullName, 0x10)  # 0x10 = overwrite
}

# Cleanup
Remove-Item $tempPath -Force
Remove-Item $extractPath -Recurse -Force
Write-Host "Fira Code Nerd Font installed." -ForegroundColor Green

# -----------------------------------------------------------------------------
# Oh My Posh PATH fix (Refresh env)
# -----------------------------------------------------------------------------
if (Get-Command oh-my-posh -ErrorAction SilentlyContinue) {
  oh-my-posh init pwsh --config "$env:USERPROFILE\.omp\jandedobbeleer.omp.json" | Out-String | Invoke-Expression
}

{{ end }}
