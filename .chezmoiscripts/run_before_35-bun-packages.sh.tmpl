#!/bin/bash

{{ if .isLinux }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"
info "Installing bun global packages..."

export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

run bun add -g \
  @anthropic-ai/claude-code \
  browser-sync \
  n8n \
  openclaw \
  opencode-ai \
  vercel \
  yarn

run bun -v
run claude -v
run browser-sync --version
run n8n -v
run openclaw -v
run opencode -v
run vercel -v
run yarn -v
success
{{ end }}
