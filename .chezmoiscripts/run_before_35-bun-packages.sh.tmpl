#!/bin/bash

{{ if .isLinux }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"
info "Installing bun global packages..."

export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"

run <<EOF
bun add -g \
  @anthropic-ai/claude-code \
  browser-sync \
  n8n \
  openclaw \
  opencode-ai \
  vercel \
  yarn
EOF

run <<EOF
bun -v | head -n1
EOF
run <<EOF
claude -v | head -n1
EOF
run <<EOF
browser-sync --version | head -n1
EOF
run <<EOF
n8n -v | head -n1
EOF
run <<EOF
openclaw -v | head -n1
EOF
run <<EOF
opencode -v | head -n1
EOF
run <<EOF
vercel -v | head -n1
EOF
run <<EOF
yarn -v | head -n1
EOF

success
{{ end }}
