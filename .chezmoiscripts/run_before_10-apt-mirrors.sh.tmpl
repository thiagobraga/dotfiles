#!/bin/bash

{{ if eq .chezmoi.os "linux" }}
{{ if or (eq .chezmoi.osRelease.id "ubuntu") (eq .chezmoi.osRelease.id "debian") }}

source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"

info "Setting up Brazilian apt mirrors..."

{{ if eq .chezmoi.osRelease.id "ubuntu" }}
if [ -f "/etc/apt/sources.list.d/ubuntu.sources" ]; then
  if grep -q "br.archive.ubuntu.com" /etc/apt/sources.list.d/ubuntu.sources; then
    success "Brazilian mirrors already configured."
  else
    sudo sed -i 's|URIs: http://[^ ]*|URIs: http://br.archive.ubuntu.com/ubuntu|' /etc/apt/sources.list.d/ubuntu.sources
    success "Brazilian mirrors configured successfully!"
  fi
else
  sudo tee /etc/apt/sources.list.d/ubuntu.sources > /dev/null << 'EOF'
Types: deb
URIs: http://br.archive.ubuntu.com/ubuntu
Suites: noble noble-updates noble-backports
Components: main universe restricted multiverse
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg

Types: deb
URIs: http://br.archive.ubuntu.com/ubuntu
Suites: noble-security
Components: main universe restricted multiverse
Signed-By: /usr/share/keyrings/ubuntu-archive-keyring.gpg
EOF
  success "Created ubuntu.sources with Brazilian mirrors."
fi
{{ else if eq .chezmoi.osRelease.id "debian" }}
sudo tee /etc/apt/sources.list >/dev/null <<EOF
deb http://ftp.br.debian.org/debian bookworm main contrib non-free non-free-firmware
deb http://ftp.br.debian.org/debian bookworm-updates main contrib non-free non-free-firmware
deb http://security.debian.org/debian-security bookworm-security main contrib non-free non-free-firmware
EOF
success "Brazilian mirrors configured for Debian."
{{ end }}

{{ end }}
{{ end }}
