#!/bin/bash

{{ if and .isLinux .isFull }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"

# Ensure cargo is available
export PATH="$HOME/.cargo/bin:$PATH"

if ! command -v cargo &>/dev/null; then
  warning "Cargo not found, skipping Rust crates installation"
  exit 0
fi

info "Installing Rust crate dependencies..."
sudo apt-get install -y \
  libasound2-dev \
  pkg-config \
  &>/dev/null
success
info "Installing Rust crates..."
# Install claurst (Claude Code in Rust)
success
info "Installing claurst..."
cargo install \
  --git https://github.com/Kuberwastaken/claurst \
  --locked &>/dev/null
success
{{ end }}
