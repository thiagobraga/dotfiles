#!/bin/bash

{{ if .isLinux }}
source "{{ .chezmoi.sourceDir }}/.helpers/utils.sh"
info "Verifying system locale settings..."

info "Generating en_US.UTF-8 locale..."
run <<EOF
sudo locale-gen en_US.UTF-8
EOF
info "Updating system default locales..."
run <<EOF
sudo update-locale LC_ALL=en_US.UTF-8 LANG=en_US.UTF-8
EOF

success
{{ end }}
