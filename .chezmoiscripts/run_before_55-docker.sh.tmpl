#!/bin/bash

{{- if and .isLinux .isFull }}

{{- if .isWsl -}}
! command -v docker &>/dev/null \
  && warning 'Docker not found in WSL. Ensure Docker Desktop is running and WSL Integration is enabled.' \
  || info 'Docker found via WSL Integration. Skipping native installation.'

{{ else -}}

if ! command -v docker &>/dev/null; then
  info "Installing Docker via official convenience script..."
  curl -fsSL https://get.docker.com -o get-docker.sh &>/dev/null \
    && sudo sh get-docker.sh &>/dev/null \
    && rm get-docker.sh &>/dev/null
else
  info "Updating Docker..."
  sudo apt-get install -y \
    containerd.io \
    docker-buildx-plugin \
    docker-ce \
    docker-ce-cli \
    docker-ce-rootless-extras \
    docker-compose-plugin \
    &>/dev/null
fi
success

if ! groups $USER | grep -q "docker"; then
  info "Adding user $USER to the docker group..."
  sudo usermod -aG docker $USER &>/dev/null
  newgrp docker &>/dev/null
  success
fi

{{ end -}}
{{- end }}
