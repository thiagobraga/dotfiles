{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [
        { "command": { "action": "newTab", "index": 1, "elevate": true }, "id": "Terminal.OpenNewTabElevatedProfile1" }
    ],
    "centerOnLaunch": true,
    "copyFormatting": "none",
    "copyOnSelect": true,
    "defaultProfile": "{1162e693-6e3b-5e04-b967-013a1d41aa3d}",
    "disableAnimations": true,
    "initialCols": 130,
    "initialRows": 40,
    "keybindings":
    [
        { "keys": "ctrl+t", "id": "Terminal.OpenNewTab" },
        { "keys": "alt+w", "id": "Terminal.ClosePane" },
        { "keys": "ctrl+tab", "id": "Terminal.MoveFocusNext" },
        { "keys": "ctrl+shift+tab", "id": "Terminal.MoveFocusPrevious" },
        { "keys": "ctrl+c", "id": "Terminal.CopyToClipboard" },
        { "keys": "ctrl+v", "id": "Terminal.PasteFromClipboard" },
        { "keys": "alt+shift+d", "id": "Terminal.DuplicatePaneAuto" },
        { "keys": "ctrl+shift+d", "id": "Terminal.DuplicateTab" },
        { "keys": "alt+1", "id": "Terminal.OpenNewTabProfile0" },
        { "keys": "alt+2", "id": "Terminal.OpenNewTabProfile1" },
        { "keys": "alt+3", "id": "Terminal.OpenNewTabProfile2" },
        { "keys": "alt+4", "id": "Terminal.OpenNewTabElevatedProfile1" },
        { "keys": "alt+enter", "id": null }
    ],
    "language": "en-US",
    "newTabMenu":
    [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles":
    {
        "defaults":
        {
            "colorScheme": "One Half Dark",
            "font":
            {
                "cellHeight": "1.5",
                "face": "FiraCode Nerd Font",
                "size": 9
            },
            "opacity": 80,
            "useAcrylic": true
        },
        "list":
        [
            {
