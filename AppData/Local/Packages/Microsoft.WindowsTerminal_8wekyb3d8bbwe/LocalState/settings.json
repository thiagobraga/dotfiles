                "hidden": false,
                "name": "Ubuntu",
                "source": "Microsoft.WSL"
            }
        ]
    },
    "rendering.disablePartialInvalidation": true,
    "rendering.graphicsAPI": "direct3d11",
    "rendering.software": true,
    "schemes": [],
    "showTerminalTitleInTitlebar": false,
    "themes": [],
    "useAcrylicInTabRow": false,
