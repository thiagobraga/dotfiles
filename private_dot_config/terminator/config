[global_config]
  handle_size = 7
  scroll_tabbar = True
  inactive_color_offset = 1.0
  enabled_plugins = ,
  suppress_multiple_term_dialog = True
  always_split_with_profile = True
  case_sensitive = False
[keybindings]
  new_tab = <Control>t
  split_horiz = <Control>d
  split_vert = <Control><Shift>d
  close_term = <Control>w
  copy = <Control>c
  paste = <Control>v
  next_tab = <Ctrl>Tab
  prev_tab = <Ctrl><Shift>Tab
  hide_window = None
  new_terminator = <Control>n
[profiles]
  [[default]]
    icon_bell = False
    background_color = "#2e3440"
    background_darkness = 0.94
    background_type = transparent
    cursor_shape = ibeam
    font = SauceCodePro Nerd Font Mono 10
    foreground_color = "#d8dee9"
    show_titlebar = False
    scrollback_lines = 5000
    scrollback_infinite = True
    palette = "#3b4252:#bf616a:#a3be8c:#ebcb8b:#81a1c1:#b48ead:#88c0d0:#e5e9f0:#616978:#bf616a:#a3be8c:#ebcb8b:#81a1c1:#b48ead:#8fbcbb:#eceff4"
    use_system_font = False
    bold_is_bright = True
[layouts]
  [[default]]
    [[[child0]]]
      fullscreen = False
      last_active_window = True
      maximised = False
      order = 0
      parent = ""
      ; position = 535, 290
      size = 850, 500
      type = Window
    [[[terminal1]]]
      order = 0
      parent = child0
      profile = default
      type = Terminal
[plugins]
