# ------------------------------------------------------------------------------
# ~/.zshrc
#
# Personal Zsh configuration for interactive shells.
#
# - Initializes environment variables, locale, PATH additions, and shell options
# - Loads Oh My Zsh with Powerlevel10k theme and selected plugins
# - Applies history improvements and safer glob behavior
# - Sources optional user files (.env, .aliases) if present
# - Configures development tools such as pyenv and project-specific paths
# - Optional zprof hooks are included for startup profiling when needed
# ------------------------------------------------------------------------------


# Import optional environment variables
# ------------------------------------------------------------
[[ -e "${HOME}/.env" ]] && source "${HOME}/.env"


# Zsh startup profiler
# ------------------------------------------------------------
ZSH_PROFILER=${ZSH_PROFILER:-false}
[[ "$ZSH_PROFILER" = true ]] && zmodload zsh/zprof || true


# Shell locale and editor settings
# ------------------------------------------------------------
export EDITOR='nvim'
export LANG='en_US.UTF-8'
export LANGUAGE='en_US.UTF-8'
export LC_ALL='en_US.UTF-8'
export TERM='xterm-256color'
{{- if not .isServer }}
export VISUAL='/usr/bin/code'
{{- end }}


# Zsh behavior options
# ------------------------------------------------------------
setopt EXTENDED_HISTORY        # Store timestamp and duration for each command in history
setopt HIST_EXPIRE_DUPS_FIRST  # Expire duplicate entries first when history reaches its size limit
setopt HIST_FIND_NO_DUPS       # Skip duplicates during history search (Ctrl-R etc.)
setopt HIST_IGNORE_ALL_DUPS    # Keep only the newest instance of duplicated commands
setopt HIST_IGNORE_DUPS        # Do not record a command if it is identical to the previous one
setopt HIST_IGNORE_SPACE       # Commands starting with a space are not stored in history
setopt HIST_SAVE_NO_DUPS       # Remove duplicate commands when writing history to file
setopt NONOMATCH               # Keep glob patterns literal if they match no files
unsetopt HIST_BEEP             # Disable beep when history search fails


# Oh My Zsh configuration
# ------------------------------------------------------------
export ZSH="${HOME}/.oh-my-zsh"
export ZSH_THEME="${ZSH_THEME:-powerlevel10k/powerlevel10k}"
export ZSH_DISABLE_COMPFIX=true
export DISABLE_AUTO_UPDATE=true
export DISABLE_MAGIC_FUNCTIONS=true
export COMPINIT_CACHE_DIR=/tmp
export plugins=(
  git
  zsh-syntax-highlighting
  zsh-autosuggestions
  {{- if .isFull }} nvm {{- end }}
)


# Load theme and framework
# ------------------------------------------------------------
[[ -e "${HOME}/.p10k.zsh" ]] && source "${HOME}/.p10k.zsh"
[[ -e "${ZSH}/oh-my-zsh.sh" ]] && source "${ZSH}/oh-my-zsh.sh"


# Load custom aliases
# ------------------------------------------------------------
[[ -e "${HOME}/.aliases" ]] && source "${HOME}/.aliases"


# PATH overrides
# ------------------------------------------------------------
# Check if the directory exists in PATH and add if it's not
add_to_path() { [[ ":${PATH}:" != *":${1}:"* ]] && export PATH="${1}:${PATH}" || true; }

add_to_path ${HOME}/.local/bin


{{- if .isFull }}
# Development Tools (NVM, Bun, Pyenv)
# ------------------------------------------------------------
# NVM (Node Version Manager)
export NVM_DIR="${HOME}/.nvm"
# [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
# [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"

# Bun
export BUN_INSTALL="${HOME}/.bun"

# Pyenv
export PYENV_ROOT="${HOME}/.pyenv"
# eval "$(pyenv init - bash)"
# eval "$(pyenv virtualenv-init -)"


# PATH overrides for Development
# ------------------------------------------------------------
add_to_path ${BUN_INSTALL}/bin
add_to_path ${PYENV_ROOT}/bin


# AI / LLM Configuration
# ------------------------------------------------------------
export OPENAI_API_BASE="http://localhost:11434/v1"
export OPENAI_API_KEY="ollama"


# Project environment variables
# ------------------------------------------------------------
export PROJECTS_DIR="${HOME}/projects"
export SELF_HOSTED_DIR="${PROJECTS_DIR}/self-hosted"
{{- end }}


# Uncomment this block to show profiling results
# ------------------------------------------------------------
[[ "$ZSH_PROFILER" = true ]] && zprof || true


