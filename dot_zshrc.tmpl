# ------------------------------------------------------------------------------
# ~/.zshrc (Minimal version)
# ------------------------------------------------------------------------------

# 1. Shell settings
# ------------------------------------------------------------
export EDITOR='nvim'
export LANG='en_US.UTF-8'
export TERM='xterm-256color'

# 2. Oh My Zsh configuration
# ------------------------------------------------------------
export ZSH="${HOME}/.oh-my-zsh"
export ZSH_THEME="agnoster"
export plugins=(git sudo node nvm python pyenv docker docker-compose zsh-syntax-highlighting zsh-autosuggestions)

# Load Oh My Zsh
source "${ZSH}/oh-my-zsh.sh"

# 3. Path & Environment
# ------------------------------------------------------------
# Helper to add directory to PATH if not already there
add_to_path() { [[ ":${PATH}:" != *":${1}:"* ]] && export PATH="${1}:${PATH}" || true; }

# Add basic bin directories
add_to_path "${HOME}/.local/bin"
add_to_path "${HOME}/.bun/bin"
add_to_path "${HOME}/.pyenv/bin"

# Project environment variables
export PROJECTS_DIR="${HOME}/projects"
export SELF_HOSTED_DIR="${PROJECTS_DIR}/self-hosted"

# 4. Custom overrides
# ------------------------------------------------------------
[[ -f "${HOME}/.aliases" ]] && source "${HOME}/.aliases"
[[ -f "${HOME}/.env" ]] && source "${HOME}/.env"

